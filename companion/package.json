{
  "name": "ds5-bridge-companion",
  "version": "1.0.0",
  "private": true,
  "description": "Windows companion app for the Pico DS5 Bridge companion firmware.",
  "author": "SundayMoments",
  "productName": "DS5 Bridge",
  "license": "AGPL-3.0-only",
  "main": "dist/main/main/main.js",
  "scripts": {
    "dev": "npm run build && electron .",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.json --noEmit",
    "build:host-audio": "dotnet publish native/HostAudioHelper/HostAudioHelper.csproj -c Release -r win-x64 --self-contained true -o native/HostAudioHelper/bin/publish/win-x64",
    "build": "npm run build:host-audio && tsc -p tsconfig.main.json && vite build",
    "package:win": "npm run build && node scripts/package-win.mjs",
    "installer:win": "npm run build && electron-builder --win nsis --x64",
    "test": "vitest run src",
    "analyze:host-audio": "node scripts/analyze-host-audio-capture.mjs",
    "visual:smoke": "npm run build && node scripts/visual-smoke.mjs",
    "layout:check": "npm run build && node scripts/layout-check.mjs"
  },
  "build": {
    "appId": "io.github.sundaymoments.ds5bridge",
    "artifactName": "DS5-Bridge-Companion-Setup-${version}.${ext}",
    "directories": {
      "output": "artifacts/installer"
    },
    "afterPack": "scripts/electron-builder-after-pack.cjs",
    "files": [
      "dist/**/*",
      "package.json",
      "node_modules/node-hid/binding-options.js",
      "node_modules/node-hid/nodehid.js",
      "node_modules/node-hid/package.json",
      "node_modules/node-hid/prebuilds/HID-win32-x64/**/*",
      "node_modules/pkg-prebuilds/bindings.js",
      "node_modules/pkg-prebuilds/lib/**/*",
      "node_modules/pkg-prebuilds/package.json"
    ],
    "extraResources": [
      {
        "from": "../assets/controllers",
        "to": "assets/controllers",
        "filter": [
          "ds5-bridge_app-icon-tile.ico",
          "ds5-bridge_app-icon-tile.png",
          "ds5-bridge_mark.png"
        ]
      },
      {
        "from": "native/HostAudioHelper/bin/publish/win-x64",
        "to": "native/HostAudioHelper",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../tools/windows",
        "to": "tools/windows",
        "filter": [
          "clean-ds5bridge-devices.ps1"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/node-hid/prebuilds/**/*.node"
    ],
    "npmRebuild": false,
    "win": {
      "icon": "../assets/controllers/ds5-bridge_app-icon-tile.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DS5 Bridge"
    }
  },
  "dependencies": {
    "node-hid": "^3.2.0"
  },
  "devDependencies": {
    "@tabler/icons-react": "^3.44.0",
    "@types/node": "^25.0.3",
    "@types/node-hid": "^1.3.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.8.10",
    "electron-builder": "^26.8.1",
    "lucide-react": "^0.561.0",
    "playwright": "^1.59.1",
    "rcedit": "^5.0.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.3",
    "vitest": "^4.0.16"
  }
}
